# ══ Docker Environment — Development ═══════════════════════════
# 複製此檔到同一目錄，命名為 .env.development 並依需求調整：
#   cp docker/envs/.env.development.example docker/envs/.env.development
#
# 勿 commit docker/envs/.env.development（已 gitignore）

# ── PostgreSQL ──────────────────────────────────────────────────
DB_USER=postgres
DB_PASS=postgres
DB_NAME=stockdb

# ── pgAdmin ─────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=pgadmin

# ── Exposed Ports（Host 對外，nginx 統一入口）────────────────────
APP_PORT=80
DB_PORT_EXPOSED=5432

# ── Internal Ports（Container 內部）────────────────────────────
BACKEND_INTERNAL_PORT=8080

# ── App ─────────────────────────────────────────────────────────
NUXT_BACKEND_URL=http://backend:8080
