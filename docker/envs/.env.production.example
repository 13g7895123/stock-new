# ══ Docker Environment — Production ════════════════════════════
# 複製此檔到同一目錄，命名為 .env.production 並填入正式值：
#   cp docker/envs/.env.production.example docker/envs/.env.production
#
# 勿 commit docker/envs/.env.production（已 gitignore）

# ── PostgreSQL ──────────────────────────────────────────────────
DB_USER=postgres
DB_PASS=CHANGE_ME_STRONG_PASSWORD
DB_NAME=stockdb

# ── pgAdmin ─────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# ── Exposed Ports（Host 對外，nginx 統一入口）────────────────────
APP_PORT=80
DB_PORT_EXPOSED=5432

# ── Internal Ports（Container 內部）────────────────────────────
BACKEND_INTERNAL_PORT=8080

# ── App ─────────────────────────────────────────────────────────
# Nuxt SSR server-side 呼叫 backend（container 內部網路名稱）
NUXT_BACKEND_URL=http://backend:8080

# ── Python Scraper （籡碼金字塔 Playwright 服務）───────────────────────
# 已由 docker-compose.yml 自動設成 SCRAPER_URL=http://scraper:5100，無需手動設定
# 如需調整 Playwright 變數，修改以下項目：
SCRAPER_CONCURRENCY=3
SCRAPER_REQUEST_DELAY=2.0
