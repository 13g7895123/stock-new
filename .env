# Database
DB_USER=postgres
DB_PASS=postgres
DB_NAME=stockdb

# Exposed ports (host machine)
FRONTEND_PORT=3000
BACKEND_PORT=8080
DB_PORT_EXPOSED=5432

# Internal app settings
BACKEND_INTERNAL_PORT=8080

# Nuxt server-side backend URL (開發時指向本機，Docker 時由 compose 覆蓋)
NUXT_BACKEND_URL=http://localhost:8080
