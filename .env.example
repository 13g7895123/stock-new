# ══════════════════════════════════════════════════════════════
#  此為舊版根目錄 .env 範本，保留供參考。
#
#  ✅  全新標準流程：
#      1. 複製環境範本：
#           cp docker/.env.production.example docker/.env.production
#           cp docker/.env.development.example docker/.env.development
#      2. 填入正確值（特別是 production 的 DB_PASS）
#      3. 啟動：
#           ./scripts/deploy.sh production
#             或
#           ./scripts/deploy.sh development
#
#  deploy.sh 會自動將 docker/.env.<env> 複製為根目錄 .env
#  供 docker compose 讀取，並同步 backend/.env 供本地開發使用。
# ══════════════════════════════════════════════════════════════

# Database
DB_USER=postgres
DB_PASS=postgres
DB_NAME=stockdb

# Exposed ports (host machine)
FRONTEND_PORT=3000
BACKEND_PORT=8080
DB_PORT_EXPOSED=5432

# Internal app settings
BACKEND_INTERNAL_PORT=8080

# Nuxt server-side backend URL
NUXT_BACKEND_URL=http://localhost:8080
